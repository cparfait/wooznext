# Variables d'environnement — wooznext
# Copier ce fichier en .env et remplir les valeurs

# --- Base de données ---
DATABASE_URL="postgresql://wooznext:wooznext_dev@localhost:5432/wooznext"

# --- Application ---
PORT=3002

# --- NextAuth.js ---
# Générer un secret fort : openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3002"

# --- RGPD ---
# Pepper pour le hachage HMAC-SHA256 des numéros de téléphone
# Générer : openssl rand -base64 32
PHONE_PEPPER="change-me-with-a-strong-random-pepper"

# --- Docker Compose (pour docker-compose.yml en production) ---
DB_PASSWORD="wooznext_secret"