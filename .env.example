# Variables d'environnement — cparfait
# Copier ce fichier en .env et remplir les valeurs

# --- Base de données ---
DATABASE_URL="postgresql://cparfait:cparfait_dev@localhost:5432/cparfait"

# --- NextAuth.js ---
# Générer un secret fort : openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Docker Compose (pour docker-compose.yml en production) ---
DB_PASSWORD="cparfait_secret"

# --- App ---
# Nom affiché dans les interfaces publiques
PUBLIC_COLLECTIVITE_NAME="Mairie"
