generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  ADMIN
  AGENT
}

enum TicketStatus {
  WAITING
  SERVING
  COMPLETED
  CANCELLED
  NO_SHOW
}

// --- Models ---

/// Service municipal (ex: État civil, Urbanisme, etc.)
model Service {
  id             String   @id @default(cuid())
  name           String   @unique
  prefix         String   @default("") // Préfixe optionnel pour les tickets (ex: "EC" pour État civil)
  isActive       Boolean  @default(true)
  feedUrl        String?  @map("feed_url") // URL du flux JSON d'actualités pour l'affichage public
  feedActive     Boolean  @default(true) @map("feed_active") // Activer/desactiver le flux sans supprimer l'URL
  tickerMessage   String?  @map("ticker_message") // Message défilant urgent pour l'affichage public
  tickerActive    Boolean  @default(true) @map("ticker_active") // Activer/desactiver le ticker sans supprimer le message
  tickerPosition  String   @default("bottom") @map("ticker_position") // top, middle, bottom
  tickerHeight    Int      @default(48) @map("ticker_height") // hauteur en px du bandeau
  tickerBgColor   String   @default("#dc2626") @map("ticker_bg_color") // couleur de fond
  tickerTextColor String   @default("#ffffff") @map("ticker_text_color") // couleur du texte
  tickerFontSize  Int      @default(18) @map("ticker_font_size") // taille du texte en px
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agents         Agent[]
  counters       Counter[]
  tickets        Ticket[]
  dailySequences DailySequence[]
  openingHours   OpeningHours[]

  @@map("services")
}

/// Agent de la collectivité (opérateur de guichet)
model Agent {
  id           String   @id @default(cuid())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(AGENT)
  serviceId    String?  @map("service_id")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service  Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  counters Counter[]
  tickets  Ticket[]  @relation("CalledBy")

  @@map("agents")
}

/// Visiteur identifié par son numéro de téléphone
model Visitor {
  id        String   @id @default(cuid())
  phone     String   @unique
  createdAt DateTime @default(now())

  tickets Ticket[]

  @@map("visitors")
}

/// Guichet physique
model Counter {
  id              String  @id @default(cuid())
  label           String // Ex: "Guichet 1", "Guichet 2"
  isActive        Boolean @default(true)
  serviceId       String  @map("service_id")
  agentId         String? @map("agent_id")
  currentTicketId String? @unique @map("current_ticket_id")

  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  agent         Agent?  @relation(fields: [agentId], references: [id])
  currentTicket Ticket? @relation("CurrentlyServing", fields: [currentTicketId], references: [id])

  @@map("counters")
}

/// Ticket de file d'attente
model Ticket {
  id          String       @id @default(cuid())
  number      Int // Numéro séquentiel du jour (1, 2, 3...)
  displayCode String       @map("display_code") // Code affiché (ex: "001", "EC-001")
  status      TicketStatus @default(WAITING)
  serviceId   String       @map("service_id")
  visitorId   String       @map("visitor_id")
  calledById  String?      @map("called_by_id")
  createdAt   DateTime     @default(now())
  calledAt    DateTime?    @map("called_at")
  completedAt DateTime?    @map("completed_at")

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  visitor  Visitor  @relation(fields: [visitorId], references: [id])
  calledBy Agent?   @relation("CalledBy", fields: [calledById], references: [id])
  counter  Counter? @relation("CurrentlyServing")

  @@index([serviceId, status])
  @@index([visitorId, status])
  @@index([createdAt])
  @@map("tickets")
}

/// Séquence quotidienne pour la numérotation des tickets par service
model DailySequence {
  id         String   @id @default(cuid())
  serviceId  String   @map("service_id")
  date       DateTime @db.Date
  lastNumber Int      @default(0) @map("last_number")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, date])
  @@map("daily_sequences")
}

/// Horaires d'ouverture par service et par jour de la semaine
model OpeningHours {
  id        String  @id @default(cuid())
  serviceId String  @map("service_id")
  dayOfWeek Int     // 0 = Lundi, 6 = Dimanche
  openTime  String  @map("open_time") // Format "HH:MM"
  closeTime String  @map("close_time") // Format "HH:MM"
  isClosed  Boolean @default(false) @map("is_closed")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, dayOfWeek])
  @@map("opening_hours")
}
